# Normalize text files to LF in repo for cross-OS consistency
* text=auto eol=lf

# Keep Windows scripts in CRLF when needed
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary files (no line-ending normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
